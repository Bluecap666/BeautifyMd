# .env - 环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥

# ========== OpenAI API 配置 ==========
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1

# ========== 国内大模型配置 ==========

# 通义千问 (阿里云)
DASHSCOPE_API_KEY=

# 文心一言 (百度)
QIANFAN_AK=your_qianfan_ak_here
QIANFAN_SK=your_qianfan_sk_here

# 讯飞星火
SPARK_API_KEY=your_spark_key_here

# 智谱 AI
ZHIPU_API_KEY=your_zhipu_key_here

# 腾讯混元
HUNYUAN_API_KEY=your_hunyuan_key_here

# 豆包大模型（字节）
DOUBAO_API_KEY=your_doubao_key_here

# ========== 模型选择 ==========
# 可选值:
# - gpt-3.5-turbo (OpenAI)
# - gpt-4 (OpenAI)
# - qwen-turbo (通义千问)
# - qwen-plus (通义千问)
# - ernie-bot (文心一言)
# - spark-v3.5 (讯飞星火)
# - chatglm_pro (智谱 AI)
# - hunyuan-lite (腾讯混元)
# - hunyuan-standard (腾讯混元)
# - doubao-pro (豆包大模型 Pro)
# - doubao-lite (豆包大模型 Lite)
DEFAULT_MODEL=gpt-3.5-turbo

# 请求超时设置 (秒)
REQUEST_TIMEOUT=120

# 最大重试次数
MAX_RETRIES=3
